# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Paddle (billing)
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=your-paddle-client-token
NEXT_PUBLIC_PADDLE_ENVIRONMENT=sandbox   # or "production"
PADDLE_API_KEY=your-paddle-api-key
PADDLE_ENVIRONMENT=sandbox               # or "production"
PADDLE_WEBHOOK_SECRET=your-webhook-secret

# Email (Resend)
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM_ADDRESS=hello@beamix.io

# OpenRouter — unified LLM gateway (replaces 4 individual AI provider keys)
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key

# Individual AI provider keys — NO LONGER NEEDED (replaced by OpenRouter above)
# ANTHROPIC_API_KEY=your-anthropic-api-key
# OPENAI_API_KEY=your-openai-api-key
# GOOGLE_AI_API_KEY=your-google-ai-api-key
# PERPLEXITY_API_KEY=your-perplexity-api-key

# Cron security (used by Vercel cron jobs)
CRON_SECRET=a-random-secret-string
