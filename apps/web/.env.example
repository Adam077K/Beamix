# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# ─── AI / LLM ─────────────────────────────────────────────────────────────────
# Claude calls go direct via Anthropic SDK (80% of traffic)
ANTHROPIC_API_KEY=
# Two separate OpenRouter keys — track scan spend vs agent spend independently
OPENROUTER_SCAN_KEY=    # used by scan engine (chatgpt/gemini/perplexity/grok queries)
OPENROUTER_AGENT_KEY=   # used by agent pipeline (research/do/qa steps)

# ─── Paddle (billing) ─────────────────────────────────────────────────────────
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
NEXT_PUBLIC_PADDLE_ENV=sandbox

# ─── Resend (email) ───────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=notify@beamix.tech
RESEND_FROM_NAME=Beamix

# ─── Inngest (background jobs) ────────────────────────────────────────────────
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ─── Upstash Redis (rate limiting) ────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Cloudflare Turnstile (bot protection) ────────────────────────────────────
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ─── Sentry (error tracking) ──────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=development

# ─── Playwright E2E Tests (dev only) ───────────────────────────────────────────
E2E_TEST_EMAIL=
E2E_TEST_PASSWORD=
BYPASS_TURNSTILE=true
